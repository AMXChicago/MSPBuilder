generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  ARCHIVED
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  ADVISOR
}

enum LifecycleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BusinessType {
  MSP
  MSSP
  HYBRID
  CO_MANAGED
}

enum DeliveryModel {
  REMOTE
  ONSITE
  HYBRID
}

enum ComplianceSensitivity {
  LOW
  MEDIUM
  HIGH
}

enum BudgetPositioning {
  BUDGET
  STANDARD
  PREMIUM
}

enum FounderMaturity {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ServiceCategory {
  HELPDESK
  SECURITY
  NETWORK
  COMPLIANCE
  CLOUD
  VCIO
}

enum PackageTier {
  GOOD
  BETTER
  BEST
  ENTERPRISE
}

enum SlaTier {
  BEST_EFFORT
  STANDARD
  PRIORITY
  TWENTY_FOUR_SEVEN
}

enum SupportHours {
  BUSINESS_HOURS
  EXTENDED_HOURS
  TWENTY_FOUR_SEVEN
}

enum PriorityLevel {
  LOW
  STANDARD
  HIGH
  CRITICAL
}

enum PricingUnit {
  USER
  DEVICE
  HYBRID
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum VendorCategory {
  PSA
  RMM
  MDR
  BACKUP
  DOCUMENTATION
  EMAIL_SECURITY
  IDENTITY
}

enum TemplateKind {
  CONTRACT
  PROPOSAL
  SOP
  CHECKLIST
  MARKETING
}

enum BaselineCategory {
  IDENTITY
  ENDPOINT
  EMAIL
  NETWORK
  BACKUP
  MONITORING
}

enum KpiUnit {
  CURRENCY
  PERCENT
  COUNT
  DAYS
}

enum RecommendationFamily {
  PRICING_READINESS
  PACKAGE_COMPLETENESS
  STACK_FIT
  SECURITY_BASELINE
}

enum ScenarioStatus {
  DRAFT
  EVALUATED
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  fullName        String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberships     OrganizationMember[]
  sessions        UserSession[]
  founderProfiles FounderProfile[]
}

model Organization {
  id                          String                        @id @default(cuid())
  name                        String
  slug                        String                        @unique
  status                      OrganizationStatus            @default(ACTIVE)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  members                     OrganizationMember[]
  founderProfiles             FounderProfile[]
  businessModels              BusinessModel[]
  serviceDefinitions          ServiceDefinition[]
  servicePackages             ServicePackage[]
  servicePackageItems         ServicePackageItem[]
  pricingModels               PricingModel[]
  vendorCosts                 VendorCostProfile[]
  vendors                     Vendor[]
  recommendationScenarios     RecommendationScenario[]
  recommendationOutputLinks   RecommendationOutputLink[]
  stackRecommendations        StackRecommendation[]
  recommendationResults       RecommendationResultRecord[]
  templates                   TemplateAsset[]
  onboardingChecklists        OnboardingChecklist[]
  onboardingChecklistSteps    OnboardingChecklistStep[]
  sopDocuments                SopDocument[]
  securityBaselines           SecurityBaseline[]
  launchCampaigns             LaunchCampaign[]
  kpiRecords                  KpiRecord[]
}

model OrganizationMember {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}


model UserSession {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
model FounderProfile {
  id                       String                     @id @default(cuid())
  organizationId           String
  userId                   String
  fullName                 String
  roleTitle                String
  priorExperienceYears     Int
  targetGeo                String
  serviceMotion            String
  maturityLevel            String
  salesConfidence          Int
  technicalDepth           Int
  preferredEngagementModel String
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  organization             Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationScenarios  RecommendationScenario[]

  @@index([organizationId, updatedAt])
}

model BusinessModel {
  id                       String                 @id @default(cuid())
  organizationId           String
  name                     String
  businessType             BusinessType
  targetVerticals          String[]
  targetCompanySizes       String[]
  deliveryModel            DeliveryModel
  complianceSensitivity    ComplianceSensitivity
  budgetPositioning        BudgetPositioning
  founderMaturity          FounderMaturity
  revenueStrategy          String
  targetGrossMarginPercent Decimal                @db.Decimal(5, 2)
  currencyCode             String                 @default("USD")
  status                   LifecycleStatus        @default(DRAFT)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recommendationScenarios  RecommendationScenario[]

  @@index([organizationId, updatedAt])
}

model ServiceDefinition {
  id                 String                 @id @default(cuid())
  organizationId     String
  name               String
  category           ServiceCategory
  description        String
  baseUnit           String
  status             LifecycleStatus        @default(DRAFT)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packageItems       ServicePackageItem[]
  vendorCostProfiles VendorCostProfile[]

  @@unique([organizationId, name])
}

model ServicePackage {
  id                       String                 @id @default(cuid())
  organizationId           String
  name                     String
  marketPosition           PackageTier
  description              String
  targetPersona            String
  includesSecurityBaseline Boolean                @default(false)
  defaultSlaTier           SlaTier
  defaultSupportHours      SupportHours
  defaultExclusions        String[]
  status                   LifecycleStatus        @default(DRAFT)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items                    ServicePackageItem[]
  pricingModels            PricingModel[]
  recommendationScenarios  RecommendationScenario[]

  @@index([organizationId, updatedAt])
}

model ServicePackageItem {
  id                  String              @id @default(cuid())
  organizationId      String
  servicePackageId    String
  serviceDefinitionId String
  isRequired          Boolean             @default(true)
  includedQuantity    Decimal             @db.Decimal(10, 2)
  slaTier             SlaTier
  supportHours        SupportHours
  exclusions          String[]
  priorityLevel       PriorityLevel       @default(STANDARD)
  notes               String?
  sortOrder           Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servicePackage      ServicePackage      @relation(fields: [servicePackageId], references: [id], onDelete: Cascade)
  serviceDefinition   ServiceDefinition   @relation(fields: [serviceDefinitionId], references: [id], onDelete: Cascade)

  @@unique([servicePackageId, serviceDefinitionId])
}

model PricingModel {
  id                      String                  @id @default(cuid())
  organizationId          String
  servicePackageId        String
  pricingUnit             PricingUnit
  currencyCode            String                  @default("USD")
  monthlyBasePrice        Decimal                 @db.Decimal(10, 2)
  onboardingFee           Decimal                 @db.Decimal(10, 2)
  minimumQuantity         Int
  includedQuantity        Int
  overageUnitPrice        Decimal                 @db.Decimal(10, 2)
  billingFrequency        BillingFrequency
  contractTermMonths      Int
  passthroughCost         Decimal                 @db.Decimal(10, 2)
  markupPercentage        Decimal                 @db.Decimal(5, 2)
  effectiveMarginPercent  Decimal?                @db.Decimal(5, 2)
  targetMarginPercent     Decimal                 @db.Decimal(5, 2)
  floorMarginPercent      Decimal                 @db.Decimal(5, 2)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  servicePackage          ServicePackage          @relation(fields: [servicePackageId], references: [id], onDelete: Cascade)
  recommendationScenarios RecommendationScenario[]

  @@index([organizationId, updatedAt])
}

model Vendor {
  id                  String                      @id @default(cuid())
  organizationId      String
  name                String
  category            VendorCategory
  websiteUrl          String?
  msspFriendly        Boolean                     @default(false)
  supportsMultiTenant Boolean                     @default(false)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  costProfiles        VendorCostProfile[]
  stackLinks          StackRecommendationVendor[]

  @@unique([organizationId, name])
}

model VendorCostProfile {
  id                  String             @id @default(cuid())
  organizationId      String
  vendorId            String
  serviceDefinitionId String?
  costBasis           PricingUnit
  unitCost            Decimal            @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor              Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  serviceDefinition   ServiceDefinition? @relation(fields: [serviceDefinitionId], references: [id], onDelete: SetNull)
}

model RecommendationScenario {
  id                     String                     @id @default(cuid())
  organizationId         String
  founderProfileId       String?
  businessModelId        String?
  servicePackageId       String?
  pricingModelId         String?
  contextVersion         String
  rulesVersion           String
  status                 ScenarioStatus             @default(DRAFT)
  founderProfileSnapshot Json?
  businessModelSnapshot  Json
  servicePackageSnapshot Json
  pricingModelSnapshot   Json
  constraintSnapshot     Json
  vendorSnapshot         Json?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  organization           Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  founderProfile         FounderProfile?            @relation(fields: [founderProfileId], references: [id], onDelete: SetNull)
  businessModel          BusinessModel?             @relation(fields: [businessModelId], references: [id], onDelete: SetNull)
  servicePackage         ServicePackage?            @relation(fields: [servicePackageId], references: [id], onDelete: SetNull)
  pricingModel           PricingModel?              @relation(fields: [pricingModelId], references: [id], onDelete: SetNull)
  outputLinks            RecommendationOutputLink[]
  stackRecommendations   StackRecommendation[]
  recommendationResults  RecommendationResultRecord[]

  @@index([organizationId, createdAt])
}

model RecommendationOutputLink {
  id                   String                 @id @default(cuid())
  organizationId       String
  scenarioId           String
  recommendationFamily RecommendationFamily
  outputId             String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scenario             RecommendationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([organizationId, scenarioId, recommendationFamily])
}

model StackRecommendation {
  id                 String                    @id @default(cuid())
  organizationId     String
  scenarioId         String
  rationale          String[]
  confidenceScore    Decimal                   @db.Decimal(4, 3)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scenario           RecommendationScenario    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  vendors            StackRecommendationVendor[]

  @@index([organizationId, scenarioId])
}

model StackRecommendationVendor {
  stackRecommendationId String
  vendorId              String
  stackRecommendation   StackRecommendation @relation(fields: [stackRecommendationId], references: [id], onDelete: Cascade)
  vendor                Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@id([stackRecommendationId, vendorId])
}

model RecommendationResultRecord {
  id                String                 @id @default(cuid())
  organizationId    String
  scenarioId        String
  overallScore      Decimal                @db.Decimal(5, 2)
  readinessLevel    String
  riskLevel         String
  confidenceLevel   String
  confidenceScore   Decimal                @db.Decimal(4, 3)
  summary           String
  resultSnapshot    Json
  detailedBreakdown Json
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scenario          RecommendationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scenarioId])
  @@index([organizationId, createdAt])
}

model TemplateAsset {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  kind           TemplateKind
  slug           String
  version        String
  status         LifecycleStatus @default(DRAFT)
  variables      String[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug, version])
}

model OnboardingChecklist {
  id             String                    @id @default(cuid())
  organizationId String
  name           String
  audience       String
  status         LifecycleStatus           @default(DRAFT)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          OnboardingChecklistStep[]
}

model OnboardingChecklistStep {
  id             String              @id @default(cuid())
  organizationId String
  checklistId    String
  title          String
  description    String
  sortOrder      Int
  ownerRole      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  checklist      OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model SopDocument {
  id             String          @id @default(cuid())
  organizationId String
  title          String
  serviceArea    String
  version        String
  status         LifecycleStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SecurityBaseline {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  category       BaselineCategory
  controlCode    String
  requirement    String
  status         LifecycleStatus  @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model LaunchCampaign {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  channel        String
  offer          String
  status         LifecycleStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model KpiRecord {
  id             String       @id @default(cuid())
  organizationId String
  metricCode     String
  metricName     String
  periodStart    DateTime
  periodEnd      DateTime
  value          Decimal      @db.Decimal(14, 4)
  unit           KpiUnit
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, metricCode, periodStart, periodEnd])
}

